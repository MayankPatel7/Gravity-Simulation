{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile C++ program",
            "command": "clang++",
            "args": [
                "src/main.cpp",
                "-o",
                "build/main",
                "-lm",
                "-lSDL3"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}